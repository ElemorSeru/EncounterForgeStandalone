<Window x:Class="EncounterForgeStandalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EncounterForgeStandalone.Converters"
        Style="{StaticResource AppWindowStyle}"
        Icon="Assets/app.ico"
        Title="Encounter Forge"
        Width="820" Height="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <conv:OutcomeColorConverter x:Key="OutcomeColor" />
    <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    <conv:InverseBoolConverter x:Key="InvBool" />
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="56" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Title bar -->
    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="20,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="ENCOUNTER FORGE" Foreground="{StaticResource AccentBrush}"
                     FontSize="16" FontWeight="Bold" />
          <TextBlock Text="  STAND-ALONE" Foreground="{StaticResource TextMutedBrush}"
                     FontSize="16" FontWeight="Light" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button Style="{StaticResource SecondaryButtonStyle}"
                  Content="Combat Intensity" Padding="12,6"
                  Click="OnCalibrateClick" Margin="0,0,8,0" />
          <Button Style="{StaticResource SecondaryButtonStyle}"
                  Content="?" Padding="10,6" FontSize="14"
                  Click="OnAboutClick" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Body -->
    <Grid Grid.Row="1" Margin="20,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="210" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="210" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Party panel -->
      <Border Grid.Column="0" Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="PARTY" Style="{StaticResource SectionLabelStyle}" />

          <TextBlock Text="Players" Style="{StaticResource FieldLabelStyle}" />
          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource SpinnerStyle}"
                     Text="{Binding PlayerCount, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding IncrementPlayerCountCommand}" Content="+" FontSize="11" />
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding DecrementPlayerCountCommand}" Content="-" FontSize="11" />
            </StackPanel>
          </Grid>

          <TextBlock Text="Level" Style="{StaticResource FieldLabelStyle}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource SpinnerStyle}"
                     Text="{Binding PlayerLevel, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding IncrementPlayerLevelCommand}" Content="+" FontSize="11" />
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding DecrementPlayerLevelCommand}" Content="-" FontSize="11" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Encounter panel -->
      <Border Grid.Column="2" Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="ENCOUNTER" Style="{StaticResource SectionLabelStyle}" />

          <TextBlock Text="Difficulty" Style="{StaticResource FieldLabelStyle}" />
          <ComboBox Margin="0,0,0,12"
                    SelectedValue="{Binding Difficulty}" SelectedValuePath="Tag">
            <ComboBoxItem Content="Easy" Tag="easy" />
            <ComboBoxItem Content="Medium" Tag="medium" />
            <ComboBoxItem Content="Hard" Tag="hard" />
            <ComboBoxItem Content="Deadly" Tag="deadly" />
          </ComboBox>

          <TextBlock Text="Theme" Style="{StaticResource FieldLabelStyle}" />
          <ComboBox Margin="0,0,0,12"
                    SelectedValue="{Binding Theme}" SelectedValuePath="Tag">
            <ComboBoxItem Content="Any" Tag="any" />
            <ComboBoxItem Content="Beast" Tag="beast" />
            <ComboBoxItem Content="Undead" Tag="undead" />
            <ComboBoxItem Content="Aberration" Tag="aberration" />
            <ComboBoxItem Content="Humanoid" Tag="humanoid" />
            <ComboBoxItem Content="Elemental" Tag="elemental" />
            <ComboBoxItem Content="Fiend" Tag="fiend" />
            <ComboBoxItem Content="Fey" Tag="fey" />
            <ComboBoxItem Content="Construct" Tag="construct" />
            <ComboBoxItem Content="Dragon" Tag="dragon" />
          </ComboBox>

          <Grid Margin="0,0,0,12"
                Visibility="{Binding EnemyCountVisible, Converter={StaticResource BoolVis}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Enemies" Style="{StaticResource FieldLabelStyle}" />
              <TextBox Style="{StaticResource SpinnerStyle}"
                       Text="{Binding EnemyCount, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding IncrementEnemyCountCommand}" Content="+" FontSize="11" />
              <RepeatButton Style="{StaticResource SpinButtonStyle}" Height="17"
                            Command="{Binding DecrementEnemyCountCommand}" Content="-" FontSize="11" />
            </StackPanel>
          </Grid>

          <CheckBox Content="Solo boss encounter" IsChecked="{Binding Solo}" />
        </StackPanel>
      </Border>

      <!-- Readout panel -->
      <Border Grid.Column="4" Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="ESTIMATE" Style="{StaticResource SectionLabelStyle}" />

          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="{Binding TargetCr}" Foreground="{StaticResource AccentGoldBrush}"
                         FontSize="28" FontWeight="Bold" />
              <TextBlock Text="Target CR" Style="{StaticResource ReadoutLabelStyle}" />
            </StackPanel>
            <Border Grid.Column="1" CornerRadius="4" Padding="12,6" VerticalAlignment="Top"
                    Background="{Binding OutcomeKey, Converter={StaticResource OutcomeColor}}">
              <TextBlock Text="{Binding Outcome}" FontWeight="SemiBold"
                         Foreground="White" FontSize="13" />
            </Border>
          </Grid>

          <Border Style="{StaticResource DividerStyle}" />

          <Grid Margin="0,8,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="{Binding EnemyDprHp}" Style="{StaticResource ReadoutValueStyle}" FontSize="12" />
              <TextBlock Text="Enemy DPR / HP" Style="{StaticResource ReadoutLabelStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="{Binding PartyDprHp}" Style="{StaticResource ReadoutValueStyle}" FontSize="12" />
              <TextBlock Text="Party DPR / HP" Style="{StaticResource ReadoutLabelStyle}" />
            </StackPanel>
          </Grid>

          <StackPanel>
            <TextBlock Text="{Binding Rounds}" Style="{StaticResource ReadoutValueStyle}" FontSize="12" />
            <TextBlock Text="Rounds to defeat / drain" Style="{StaticResource ReadoutLabelStyle}" />
          </StackPanel>

          <Border Style="{StaticResource DividerStyle}" Margin="0,16,0,8" />

          <TextBlock Text="Estimate reflects party vs. the encounter at the chosen difficulty. Generated creatures are calibrated to hit these targets."
                     Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                     TextWrapping="Wrap" LineHeight="17" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
            Padding="20,14">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
            <Run Text="{Binding Theme, StringFormat='Theme: {0}'}" />
            <Run Text=" / " Foreground="{StaticResource BorderBrush}" />
            <Run Text="{Binding Difficulty, StringFormat='Difficulty: {0}'}" />
          </TextBlock>
          <TextBlock Text="{Binding IntensityLabel}" FontSize="11"
                     Foreground="{StaticResource AccentBrush}" Margin="8,0,0,0"
                     Visibility="{Binding HasIntensityOffset, Converter={StaticResource BoolVis}}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="CloseBtn" Style="{StaticResource SecondaryButtonStyle}" Content="Close"
                  Click="OnCloseClick" Padding="32,8" />
          <FrameworkElement Width="{Binding ActualWidth, ElementName=CloseBtn}" />
          <Button Style="{StaticResource PrimaryButtonStyle}"
                  Content="Generate Encounter"
                  Command="{Binding GenerateCommand}"
                  IsEnabled="{Binding IsGenerating, Converter={StaticResource InvBool}}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
