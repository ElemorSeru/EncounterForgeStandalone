<Window x:Class="EncounterForgeStandalone.Views.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EncounterForgeStandalone.Converters"
        Style="{StaticResource AppWindowStyle}"
        Icon="/Assets/app.ico"
        Title="Combat Intensity"
        Width="500"
        SizeToContent="Height"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <conv:OutcomeColorConverter x:Key="OutcomeColor" />
    <conv:InverseBoolConverter x:Key="InvBool" />
    <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    <conv:RoundsToWidthConverter x:Key="RoundsWidth" />
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <TextBlock Text="COMBAT INTENSITY" Foreground="{StaticResource AccentBrush}"
                 FontSize="14" FontWeight="Bold"
                 VerticalAlignment="Center" Margin="20,0" />
    </Border>

    <StackPanel Grid.Row="1" Margin="20,16,20,20">

      <!-- Offset display -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{Binding OffsetDisplay}" FontSize="36" FontWeight="Bold"
                       Foreground="{StaticResource AccentGoldBrush}" />
            <TextBlock Text="{Binding StepLabel}" Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" Margin="0,2,0,0" />
          </StackPanel>
          <!-- + on top, - on bottom -->
          <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="+"
                    Command="{Binding IncrementCommand}"
                    IsEnabled="{Binding AtMax, Converter={StaticResource InvBool}}"
                    Width="38" Height="38" FontSize="20" Padding="4,0" Margin="0,0,0,6" />
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="-"
                    Command="{Binding DecrementCommand}"
                    IsEnabled="{Binding AtMin, Converter={StaticResource InvBool}}"
                    Width="38" Height="38" FontSize="20" Padding="4,0" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Pip steps -->
      <UniformGrid Rows="1" Columns="7" Margin="0,0,0,14">
        <Button Content="-3" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="-3"
                Height="32" Margin="2,0" />
        <Button Content="-2" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="-2"
                Height="32" Margin="2,0" />
        <Button Content="-1" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="-1"
                Height="32" Margin="2,0" />
        <Button Content="0" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="0"
                Height="32" Margin="2,0"
                Foreground="{StaticResource AccentGoldBrush}" />
        <Button Content="+1" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="1"
                Height="32" Margin="2,0" />
        <Button Content="+2" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="2"
                Height="32" Margin="2,0" />
        <Button Content="+3" Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding SetOffsetCommand}" CommandParameter="3"
                Height="32" Margin="2,0" />
      </UniformGrid>

      <!-- DPR-First Mode -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
        <StackPanel>
          <CheckBox IsChecked="{Binding DprFirst, Mode=TwoWay}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontWeight="SemiBold" FontSize="13">
            DPR-First Damage
          </CheckBox>
          <TextBlock TextWrapping="Wrap" FontSize="11" Margin="22,6,0,0"
                     Foreground="{StaticResource TextMutedBrush}" LineHeight="17">
            When enabled, creature damage dice are calculated directly from the encounter's
            DPR target before any calibration. This produces creatures whose damage output
            precisely matches the encounter budget, at the cost of less conventional dice
            expressions. Useful for tight balance testing across party configurations.
            When disabled, dice come from archetype tier tables and are nudged by the
            calibrator afterward (default behavior, matches most playtests).
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- Preview table -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="PREVIEW - 4 players, level 5" Style="{StaticResource SectionLabelStyle}"
                     FontSize="10" Margin="0,0,0,8" />

          <!-- Column headers -->
          <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="52" />
              <ColumnDefinition Width="52" />
              <ColumnDefinition Width="78" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Difficulty"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" />
            <StackPanel Grid.Column="1" Margin="8,0">
              <TextBlock Text="Defeat" FontSize="9"
                         Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="Drain" FontSize="9"
                         Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="Defeat"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="3" Text="Drain"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="4" Text="Outcome"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Right" />
          </Grid>

          <ItemsControl ItemsSource="{Binding DiffRows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="78" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding Difficulty}" FontSize="12"
                             Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />

                  <!-- Double bars: defeat (top) + drain (bottom) -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <Grid Height="5" Margin="0,1">
                      <Border Background="{StaticResource ElevatedBrush}" CornerRadius="2.5" />
                      <Border HorizontalAlignment="Left" CornerRadius="2.5"
                              Background="{StaticResource OutcomeEasyBrush}">
                        <Border.Width>
                          <MultiBinding Converter="{StaticResource RoundsWidth}">
                            <Binding Path="Defeat" />
                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                          </MultiBinding>
                        </Border.Width>
                      </Border>
                    </Grid>
                    <Grid Height="5" Margin="0,1">
                      <Border Background="{StaticResource ElevatedBrush}" CornerRadius="2.5" />
                      <Border HorizontalAlignment="Left" CornerRadius="2.5"
                              Background="{StaticResource AccentGoldBrush}">
                        <Border.Width>
                          <MultiBinding Converter="{StaticResource RoundsWidth}">
                            <Binding Path="Threaten" />
                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                          </MultiBinding>
                        </Border.Width>
                      </Border>
                    </Grid>
                  </StackPanel>

                  <TextBlock Grid.Column="2" Text="{Binding Defeat, StringFormat='{}{0:F1}'}"
                             FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Grid.Column="3" Text="{Binding Threaten, StringFormat='{}{0:F1}'}"
                             FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"
                             Foreground="{StaticResource AccentGoldBrush}" />
                  <Border Grid.Column="4" CornerRadius="3" Padding="6,2" Margin="8,0,0,0"
                          HorizontalAlignment="Right" VerticalAlignment="Center"
                          Background="{Binding Outcome, Converter={StaticResource OutcomeColor}}">
                    <TextBlock Text="{Binding Outcome}" FontSize="10" Foreground="White" />
                  </Border>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Style="{StaticResource DividerStyle}" />

          <!-- Legend -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Border Width="12" Height="5" CornerRadius="2.5" Margin="0,0,6,0" VerticalAlignment="Center"
                    Background="{StaticResource OutcomeEasyBrush}" />
            <TextBlock Text="Defeat - rounds until party wins" FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Border Width="12" Height="5" CornerRadius="2.5" Margin="0,0,6,0" VerticalAlignment="Center"
                    Background="{StaticResource AccentGoldBrush}" />
            <TextBlock Text="Drain - rounds party can sustain" FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                     TextWrapping="Wrap" LineHeight="17">
            Positive values make encounters feel harder. Negative values make them more forgiving.
          </TextBlock>
        </StackPanel>
      </Border>

      <Grid Margin="0,12,0,0">
        <Button Content="Reset to Default" Command="{Binding ResetCommand}"
                HorizontalAlignment="Left">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsNotDefault}" Value="False">
                  <Setter Property="Visibility" Value="Hidden" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close"
                HorizontalAlignment="Right" Click="OnCloseClick" />
      </Grid>

    </StackPanel>
  </Grid>
</Window>
